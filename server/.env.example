TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
PORT=3000

/**
Setup steps                                               
             
  1. Get a Twilio account — free trial at twilio.com, costs ~$1/SMS + call
                                                                                                                                                              
  2. Configure the server:                                                                                                                                    
  cd ElderGuard/server                                                                                                                                        
  cp .env.example .env                                                                                                                                        
  # Edit .env with your Twilio Account SID, Auth Token, and phone number
  npm start                                                             
                                                                                                                                                              
  3. Expose it to your phone (for local testing):
  # Install ngrok if needed: brew install ngrok                                                                                                               
  ngrok http 3000                                           
  # Copy the https://xxxx.ngrok.io URL                                                                                                                        
                                                            
  4. In the app → Settings → paste the ngrok URL + /emergency into the "Emergency Server URL" field → Save                                                    
                                                                                                                                                              
  5. Trigger a test alert → let the 30s countdown expire → SMS and call should arrive automatically with no taps required.     
**/
